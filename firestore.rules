/**
 * @file Firestore Security Rules for Broos 2.0 application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user data and allows for club data management.
 * A user with the 'responsible' role has read-access to all data within their associated club.
 *
 * Data Structure:
 * - /users/{userId}: Stores private user data, including role, email verification status, and associated club ID (clubId).
 * - /users/{userId}/wellnessScores/{scoreId}: Stores daily wellness scores for a user.
 * - /users/{userId}/trainings/{trainingId}: Stores individual training sessions for a user.
 * - /users/{userId}/chats/{chatId}**: Stores chat sessions and messages.
 * - /users/{userId}/alerts/{alertId}: Stores alerts triggered by the AI for a user.
 * - /users/{userId}/updates/{updateId}: Stores AI-generated insights for the player.
 * - /clubs/{clubId}: Stores club data, with a 1:1 relationship to a user who is responsible for the club.
 * - /clubs/{clubId}/teams/{teamId}: Stores team data as a subcollection of a club.
 * - /clubs/{clubId}/teams/{teamId}/summaries/{summaryId}: Stores aggregated team wellness data.
 *
 * Key Security Decisions:
 * - A 'responsible' user can read data of any user.
 * - A user can always create and manage their own private data.
 * - Listing all users globally is forbidden for regular users to prevent data leakage.
 * - A responsible user can manage their club and associated teams.
 *
 * Denormalization for Authorization:
 * - The `User` document contains `clubId` and `teamId`, allowing rules to make authorization decisions without excessive reads.
 */
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    // Checks if the requesting user has the 'responsible' role in their own document.
    function isResponsible() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'responsible';
    }

    function userHasClub() {
      let userData = getUserData(request.auth.uid);
      return userData.clubId != null && exists(/databases/$(database)/documents/clubs/$(userData.clubId));
    }
    
    function isClubOwner(clubId) {
      // Must be a responsible user AND the clubId in their user doc must match the club they're trying to access.
      return isResponsible() && getUserData(request.auth.uid).clubId == clubId;
    }

    // --- Rules ---

    match /users/{userId} {
      // READ: Allow if user is the owner OR if the requesting user is a 'responsible'.
      allow get: if isSignedIn() && (isOwner(userId) || isResponsible());
      
      // LIST: ONLY a 'responsible' user can list/query the users collection.
      allow list: if isResponsible();

      // WRITE: ONLY the owner can write to their own document. This is strict.
      allow write: if isSignedIn() && isOwner(userId);
      
      match /wellnessScores/{scoreId} {
        // A responsible user can read the wellness scores of any user.
        allow read: if (isSignedIn() && isOwner(userId)) || isResponsible();
        allow write: if isSignedIn() && isOwner(userId);
      }

      match /trainings/{trainingId} {
        allow read: if (isSignedIn() && isOwner(userId)) || isResponsible();
        allow write: if isSignedIn() && isOwner(userId);
      }
      
      match /chats/{chatId} {
        allow read: if (isSignedIn() && isOwner(userId)) || isResponsible();
        allow write: if isSignedIn() && isOwner(userId);
        
        match /messages/{messageId} {
          allow read: if (isSignedIn() && isOwner(userId)) || isResponsible();
          allow write: if isSignedIn() && isOwner(userId);
        }
      }

      match /alerts/{alertId} {
        allow create: if isSignedIn() && isOwner(userId);
        allow read, update, delete: if isResponsible(); 
      }

      match /updates/{updateId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow write: if false;
      }
    }
    
    match /{path=**}/teams/{teamId} {
      // Allow any signed-in user to find a team by its invitation code.
      allow list: if isSignedIn() && request.query.keys().hasAny(['where']) && request.query.where[0][0] == 'invitationCode';
    }


    match /clubs/{clubId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isResponsible() && !userHasClub();
      allow update, delete: if isClubOwner(clubId);

      match /clubUpdates/{updateId} {
        allow read: if isClubOwner(clubId);
        allow write: if false;
      }

      match /teams/{teamId} {
        allow get: if isSignedIn();
        allow list: if isClubOwner(clubId);
        allow create, update, delete: if isClubOwner(clubId);

        match /summaries/{summaryId} {
            allow read, write: if isClubOwner(clubId);
        }

        match /staffUpdates/{updateId} {
            allow read: if isClubOwner(clubId);
            allow write: if false;
        }
      }
    }
  }
}
