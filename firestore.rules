/**
 * @file Firestore Security Rules for RoleVerify application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user data and allows for club data management.
 *
 * Data Structure:
 * - /users/{userId}: Stores private user data, including role, email verification status, and associated club ID (clubId).
 * - /users/{userId}/wellnessScores/{scoreId}: Stores daily wellness scores for a user.
 * - /users/{userId}/trainings/{trainingId}: Stores individual training sessions for a user.
 * - /users/{userId}/chats/{chatId}**: Stores chat sessions and messages.
 * - /users/{userId}/alerts/{alertId}: Stores alerts triggered by the AI for a user.
 * - /users/{userId}/updates/{updateId}: Stores AI-generated insights for the player.
 * - /clubs/{clubId}: Stores club data, with a 1:1 relationship to a user who is responsible for the club.
 * - /clubs/{clubId}/teams/{teamId}: Stores team data as a subcollection of a club.
 * - /clubs/{clubId}/teams/{teamId}/summaries/{summaryId}: Stores aggregated team wellness data.
 *
 * Key Security Decisions:
 * - User listing is denied to prevent information leakage.
 * - A user can create their own user document upon registration.
 * - Club data access is controlled by user roles (only 'responsible' users can manage clubs).
 * - A responsible user can only create a club if they don't already have one.
 * - The owner of a club can manage teams and summaries within that club.
 * - Any signed-in user can query across all teams to find one by invitation code.
 * - A user can only read and write their own private data (wellness, chats, alerts, updates). Staff will be given read access later.
 *
 * Denormalization for Authorization:
 * - The `User` document contains the `clubId`, allowing rules on both `/users/{userId}` and `/clubs/{clubId}` to make authorization decisions without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows signed-in users to query across all teams to find one by invitation code.
     * This is a collection group query and must be at the top level.
     * @path /teams/{teamId}
     */
    match /{path=**}/teams/{teamId} {
      allow get, list: if isSignedIn();
    }

    /**
     * @description Enforces access control for user documents and their subcollections.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
      
      /**
       * @description Enforces access control for user's wellness scores.
       * @path /users/{userId}/wellnessScores/{scoreId}
       */
      match /wellnessScores/{scoreId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

      /**
       * @description Enforces access control for user's individual trainings.
       * @path /users/{userId}/trainings/{trainingId}
       */
      match /trainings/{trainingId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
      
      /**
       * @description Enforces access control for user's chat data.
       * @path /users/{userId}/chats/{chatId}
       */
      match /chats/{chatId} {
        allow read, write: if isSignedIn() && isOwner(userId);
        
        /**
         * @description Enforces access control for messages within a chat.
         * @path /users/{userId}/chats/{chatId}/messages/{messageId}
         */
        match /messages/{messageId} {
          allow read, write: if isSignedIn() && isOwner(userId);
        }
      }

      /**
       * @description Enforces access control for user's alerts.
       * @path /users/{userId}/alerts/{alertId}
       */
      match /alerts/{alertId} {
        // Users can create their own alerts (via the AI)
        allow create: if isSignedIn() && isOwner(userId);
        // Reading alerts will be restricted to staff in a later rule.
        allow read, update, delete: if false; 
      }

      /**
       * @description Enforces access control for user's updates.
       * @path /users/{userId}/updates/{updateId}
       */
      match /updates/{updateId} {
        // Users can read their own updates.
        allow read: if isSignedIn() && isOwner(userId);
        // Updates are created by a backend process, not directly by users.
        allow write: if false;
      }
    }

    /**
     * @description Enforces access control for club and team documents.
     * @path /clubs/{clubId}
     */
    match /clubs/{clubId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isResponsible() && !userHasClub();
      // Allow updates and deletes only by the responsible user who owns the club
      allow update, delete: if isSignedIn() && isResponsible() && isClubOwner(clubId);

      /**
       * @description Enforces access control for club-level updates.
       * @path /clubs/{clubId}/clubUpdates/{updateId}
       */
      match /clubUpdates/{updateId} {
        allow read: if isClubOwner(clubId);
        allow write: if false; // Only backend processes can write
      }

      /**
       * @description Enforces access control for team documents within a club.
       * @path /clubs/{clubId}/teams/{teamId}
       */
      match /teams/{teamId} {
        // This rule is for direct access, not collection group queries.
        allow get: if isSignedIn();
        // Allow team management only by the club owner.
        allow create, update, delete: if isClubOwner(clubId);

        /**
         * @description Enforces access control for team summaries.
         * @path /clubs/{clubId}/teams/{teamId}/summaries/{summaryId}
         */
        match /summaries/{summaryId} {
            // Only the club owner can create/manage team summaries.
            allow read, write: if isClubOwner(clubId);
        }

        /**
         * @description Enforces access control for staff updates on a team.
         * @path /clubs/{clubId}/teams/{teamId}/staffUpdates/{updateId}
         */
        match /staffUpdates/{updateId} {
            // Club owner and assigned staff (future rule) can read.
            allow read: if isClubOwner(clubId);
            allow write: if false; // Only backend processes can write
        }
      }
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isResponsible() {
        return getUserData(request.auth.uid).role == 'responsible';
    }

    function userHasClub() {
      let userData = getUserData(request.auth.uid);
      return userData.clubId != null && exists(/databases/$(database)/documents/clubs/$(userData.clubId));
    }
    
    // Check ownership for existing clubs
    function isClubOwner(clubId) {
      let user = getUserData(request.auth.uid);
      return isSignedIn() 
        && user.role == 'responsible'
        && user.clubId == clubId;
    }
  }
}
