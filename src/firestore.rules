/**
 * @file Firestore Security Rules for Broos 2.0 application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user data and allows for club data management.
 * A user with the 'responsible' role has read-access to all data within their associated club.
 *
 * Data Structure:
 * - /users/{userId}: Stores private user data, including role, email verification status, and associated club ID (clubId).
 * - /users/{userId}/wellnessScores/{scoreId}: Stores daily wellness scores for a user.
 * - /users/{userId}/trainings/{trainingId}: Stores individual training sessions for a user.
 * - /users/{userId}/chats/{chatId}**: Stores chat sessions and messages.
 * - /users/{userId}/alerts/{alertId}: Stores alerts triggered by the AI for a user.
 * - /users/{userId}/updates/{updateId}: Stores AI-generated insights for the player.
 * - /clubs/{clubId}: Stores club data, with a 1:1 relationship to a user who is responsible for the club.
 * - /clubs/{clubId}/teams/{teamId}: Stores team data as a subcollection of a club.
 * - /clubs/{clubId}/teams/{teamId}/summaries/{summaryId}: Stores aggregated team wellness data.
 *
 * Key Security Decisions:
 * - A 'responsible' user can read data of any user belonging to a team within their club.
 * - A user can always create and manage their own private data.
 * - Listing all users globally is forbidden to prevent data leakage, EXCEPT for a 'responsible' user.
 * - A responsible user can manage their club and associated teams.
 *
 * Denormalization for Authorization:
 * - The `User` document contains `clubId` and `teamId`, allowing rules to make authorization decisions without excessive reads.
 */
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isResponsible() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'responsible';
    }
    
    function isClubResponsibleForTargetUser(targetUserId) {
        let responsibleData = getUserData(request.auth.uid);
        let targetUserData = getUserData(targetUserId);

        // A responsible must have a clubId. A target user must have a clubId to be checked.
        if (responsibleData.clubId == null || targetUserData.clubId == null) {
            return false;
        }
        
        // The user making the request must have the responsible role.
        if (responsibleData.role != 'responsible') {
            return false;
        }

        // The club IDs must match.
        return responsibleData.clubId == targetUserData.clubId;
    }

    function userHasClub() {
      let userData = getUserData(request.auth.uid);
      return userData.clubId != null && exists(/databases/$(database)/documents/clubs/$(userData.clubId));
    }
    
    function isClubOwner(clubId) {
      // Must be a responsible user AND the clubId in their user doc must match the club they're trying to access.
      return isResponsible() && getUserData(request.auth.uid).clubId == clubId;
    }

    /**
     * @description Logs debug information for failed requests.
     * Always returns false so it can be used in a rule chain.
     */
    function debug(message) {
      return debug({
        "rule_message": message,
        "request_auth_uid": request.auth.uid,
        "request_auth_role_from_doc": getUserData(request.auth.uid).role,
        "request_method": request.method,
        "request_path": request.path,
        "resource_data": resource.data,
        "request_query": request.query,
        "requesting_user_clubId": getUserData(request.auth.uid).clubId,
      });
    }

    // --- Rules ---

    match /{path=**}/teams/{teamId} {
      // This is a collection group query, be careful. Only allow reads if there is a where clause on invitationCode.
      allow get: if isSignedIn() || debug("Allow any signed in user to get team");
      allow list: if isSignedIn() && request.query.keys().hasAny(['where']) && request.query.where[0][0] == 'invitationCode' || debug("Allow any signed in user to find a team by code");
    }

    match /users/{userId} {
      allow get: if (isSignedIn() && isOwner(userId)) || isClubResponsibleForTargetUser(userId) || isResponsible() || debug("Allow owner, club responsible, or any responsible to get user");
      
      // A responsible can list ALL users (for migration).
      // Other users can list users IF filtered by clubId (for team views).
      allow list: if isResponsible() || 
                    (isSignedIn()
                    && request.query.keys().hasAny(['where']) 
                    && request.query.where.map(w => w[0] == 'clubId').hasAny([true]))
                    || debug("Allow responsible to list all users, or others to list if filtered by clubId");


      allow create: if isSignedIn() && isOwner(userId) || debug("Allow owner to create user doc");
      // A user can update their own doc. A responsible can update ANY user doc.
      allow update: if (isSignedIn() && isOwner(userId)) || isResponsible() || debug("Allow owner or responsible to update user doc");
      allow delete: if isSignedIn() && isOwner(userId) || debug("Allow owner to delete user doc");
      
      match /wellnessScores/{scoreId} {
        allow read, write: if (isSignedIn() && isOwner(userId)) || isClubResponsibleForTargetUser(userId) || debug("Allow owner or club responsible to read/write wellness");
      }

      match /trainings/{trainingId} {
        allow read, write: if (isSignedIn() && isOwner(userId)) || isClubResponsibleForTargetUser(userId) || debug("Allow owner or club responsible to read/write trainings");
      }
      
      match /chats/{chatId} {
        allow read, write: if (isSignedIn() && isOwner(userId)) || isClubResponsibleForTargetUser(userId) || debug("Allow owner or club responsible to read/write chats");
        
        match /messages/{messageId} {
          allow read, write: if (isSignedIn() && isOwner(userId)) || isClubResponsibleForTargetUser(userId) || debug("Allow owner or club responsible to read/write chat messages");
        }
      }

      match /alerts/{alertId} {
        allow create: if isSignedIn() && isOwner(userId) || debug("Allow owner to create alerts");
        allow read, update, delete: if isClubResponsibleForTargetUser(userId) || debug("Allow club responsible to manage alerts"); 
      }

      match /updates/{updateId} {
        allow read: if isSignedIn() && isOwner(userId) || debug("Allow owner to read their updates");
        allow write: if false;
      }
    }

    match /clubs/{clubId} {
      allow get: if isSignedIn() || debug("Allow any signed in user to get club");
      allow list: if isSignedIn() || debug("Allow any signed in user to list clubs");
      allow create: if isResponsible() && !userHasClub() || debug("Allow responsible without a club to create one");
      allow update, delete: if isClubOwner(clubId) || debug("Allow club owner to update/delete club");

      match /clubUpdates/{updateId} {
        allow read: if isClubOwner(clubId) || debug("Allow club owner to read club updates");
        allow write: if false; // Only backend processes can write
      }

      match /teams/{teamId} {
        allow get: if isSignedIn() || debug("Allow signed in users to get team");
        allow list: if isClubOwner(clubId) || debug("Allow club owner to list their own teams");
        allow create, update, delete: if isClubOwner(clubId) || debug("Allow club owner to manage teams");

        match /summaries/{summaryId} {
            allow read, write: if isClubOwner(clubId) || debug("Allow club owner to r/w summaries");
        }

        match /staffUpdates/{updateId} {
            allow read: if isClubOwner(clubId) || debug("Allow club owner to read staff updates");
            allow write: if false;
        }
      }
    }
  }
}
