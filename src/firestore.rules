/**
 * @file Firestore Security Rules for Broos 2.0 application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user data and allows for club data management.
 * A user with the 'responsible' role has read-access to all data within their associated club.
 *
 * Data Structure:
 * - /users/{userId}: Stores private user data, including role, email verification status, and associated club ID (clubId).
 * - /users/{userId}/wellnessScores/{scoreId}: Stores daily wellness scores for a user.
 * - /users/{userId}/trainings/{trainingId}: Stores individual training sessions for a user.
 * - /users/{userId}/chats/{chatId}**: Stores chat sessions and messages.
 * - /users/{userId}/alerts/{alertId}: Stores alerts triggered by the AI for a user.
 * - /users/{userId}/updates/{updateId}: Stores AI-generated insights for the player.
 * - /clubs/{clubId}: Stores club data, with a 1:1 relationship to a user who is responsible for the club.
 * - /clubs/{clubId}/teams/{teamId}: Stores team data as a subcollection of a club.
 * - /clubs/{clubId}/teams/{teamId}/summaries/{summaryId}: Stores aggregated team wellness data.
 *
 * Key Security Decisions:
 * - A 'responsible' user can read data of any user belonging to a team within their club.
 * - A user can always create and manage their own private data.
 * - Listing all users globally is forbidden to prevent data leakage.
 * - A responsible user can manage their club and associated teams.
 *
 * Denormalization for Authorization:
 * - The `User` document contains `clubId` and `teamId`, allowing rules to make authorization decisions without excessive reads.
 */
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isResponsible() {
      // Rely on custom claims for performance and security.
      // The role in the user document can be used for UI purposes, but rules should use claims.
      return request.auth.token.role == 'responsible';
    }

    function userHasClub() {
      let userData = getUserData(request.auth.uid);
      return userData.clubId != null && exists(/databases/$(database)/documents/clubs/$(userData.clubId));
    }
    
    function isClubOwner(clubId) {
      return isResponsible() && getUserData(request.auth.uid).clubId == clubId;
    }
    
    // Checks if the responsible user is authorized to access the target user's data.
    // This is true if the target user's clubId matches the responsible user's clubId.
    function isClubResponsibleForTargetUser(targetUserId) {
        let responsibleData = getUserData(request.auth.uid);
        let targetUserData = getUserData(targetUserId);

        if (responsibleData.clubId == null || targetUserData.clubId == null) {
            return false;
        }
        
        return isResponsible() && responsibleData.clubId == targetUserData.clubId;
    }

    /**
     * @description Logs debug information for failed requests.
     * Always returns false so it can be used in a rule chain.
     */
    function debug(message, details) {
      return debug({
        "rule_message": message,
        "details": details,
        "request": {
          "auth_uid": request.auth.uid,
          "auth_role_claim": request.auth.token.role,
          "method": request.method,
          "path": request.path,
          "query": request.query
        }
      });
    }

    // --- Rules ---

    match /{path=**}/teams/{teamId} {
      // This is a collection group query, be careful. Only allow reads if there is a where clause on invitationCode.
      allow get: if isSignedIn() || debug("Allow any signed in user to get team", null);
      allow list: if isSignedIn() && request.query.keys().hasAny(['where']) && request.query.where[0][0] == 'invitationCode' || debug("Allow any signed in user to find a team by code", null);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isClubResponsibleForTargetUser(userId) || debug("Allow owner or club responsible to get user", {"targetUserId": userId});
      
      // Allow a responsible user to list users, but ONLY if they filter by a clubId that matches their own.
      // This is the CRUCIAL rule for the team members page.
      allow list: if isResponsible()
                    && getUserData(request.auth.uid).clubId != null
                    && request.query.keys().hasAny(['where'])
                    && request.query.where.map(w => w[0] == 'clubId' && w[2] == getUserData(request.auth.uid).clubId).hasAny([true])
                    || debug("Allow responsible to list users ONLY when filtered by their own clubId", null);
      
      allow create: if isOwner(userId) || debug("Allow owner to create user doc", null);
      allow update: if isOwner(userId) || debug("Allow owner to update user doc", null);
      allow delete: if isOwner(userId) || debug("Allow owner to delete user doc", null);
      
      match /wellnessScores/{scoreId} {
        allow read, write: if isOwner(userId) || isClubResponsibleForTargetUser(userId) || debug("Allow owner or club responsible to read/write wellness", {"targetUserId": userId});
      }

      match /trainings/{trainingId} {
        allow read, write: if isOwner(userId) || isClubResponsibleForTargetUser(userId) || debug("Allow owner or club responsible to read/write trainings", {"targetUserId": userId});
      }
      
      match /chats/{chatId} {
        allow read, write: if isOwner(userId) || isClubResponsibleForTargetUser(userId) || debug("Allow owner or club responsible to read/write chats", {"targetUserId": userId});
        
        match /messages/{messageId} {
          allow read, write: if isOwner(userId) || isClubResponsibleForTargetUser(userId) || debug("Allow owner or club responsible to read/write chat messages", {"targetUserId": userId});
        }
      }

      match /alerts/{alertId} {
        allow create: if isOwner(userId) || debug("Allow owner to create alerts", null);
        allow read, update, delete: if isClubResponsibleForTargetUser(userId) || debug("Allow club responsible to manage alerts", {"targetUserId": userId}); 
      }

      match /updates/{updateId} {
        allow read: if isOwner(userId) || debug("Allow owner to read their updates", null);
        allow write: if false;
      }
    }

    match /clubs/{clubId} {
      allow get: if isSignedIn() || debug("Allow any signed in user to get club", null);
      allow list: if isSignedIn() || debug("Allow any signed in user to list clubs", null);
      allow create: if isResponsible() && !userHasClub() || debug("Allow responsible without a club to create one", null);
      allow update, delete: if isClubOwner(clubId) || debug("Allow club owner to update/delete club", {"clubId": clubId});

      match /clubUpdates/{updateId} {
        allow read: if isClubOwner(clubId) || debug("Allow club owner to read club updates", {"clubId": clubId});
        allow write: if false;
      }

      match /teams/{teamId} {
        allow get: if isSignedIn() || debug("Allow signed in users to get team", null);
        allow list: if isClubOwner(clubId) || debug("Allow club owner to list their own teams", {"clubId": clubId});
        allow create, update, delete: if isClubOwner(clubId) || debug("Allow club owner to manage teams", {"clubId": clubId});

        match /summaries/{summaryId} {
            allow read, write: if isClubOwner(clubId) || debug("Allow club owner to r/w summaries", {"clubId": clubId});
        }

        match /staffUpdates/{updateId} {
            allow read: if isClubOwner(clubId) || debug("Allow club owner to read staff updates", {"clubId": clubId});
            allow write: if false;
        }
      }
    }
  }
}
